# ============================================
# Smart AI Interview Assistant — Environment
# ============================================
# Copy this file to .env and fill in your values.

# ── Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── JWT Authentication ──
JWT_SECRET_KEY=change-me-to-a-random-64-char-string

# ── Admin Account (created on first startup) ──
ADMIN_EMAIL=admin@smartai.com
ADMIN_PASSWORD=change-me-strong-password

# ── Database ──
# Set USE_MONGODB=true and provide a full URI for production.
# Leave MONGODB_URI empty to use SQLite fallback (dev/demo mode).
USE_MONGODB=false
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=MyApp

# ── Inference ──
# "cpu" for most machines, "cuda" if you have an NVIDIA GPU with CUDA
INFERENCE_DEVICE=cpu
AI_SAFE_MODE=true

# ── Frontend (used at Docker build time) ──
VITE_API_URL=http://localhost:8000
